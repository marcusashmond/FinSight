{
  "name": "finsight-backend",
  "version": "1.0.0",
  "description": "REST API for FinSight — personal finance tracking with JWT auth, analytics, and budget management",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:unit": "jest --testPathPattern=__tests__/.*(?<!integration).test.js --detectOpenHandles",
    "test:integration": "jest --testPathPattern=integration --detectOpenHandles --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 120000,
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.3",
    "supertest": "^7.0.0"
  }
}
